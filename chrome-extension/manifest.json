{
  "manifest_version": 3,
  "name": "YouTube SEO 分析器",
  "version": "1.6",
  "description": "一鍵分析 YouTube 影片 SEO + 縮圖視覺分析，支援 Shorts，提供優化建議",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://i.ytimg.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch?v=*",
        "https://www.youtube.com/shorts/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
